{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "contacts-search",
  "title": "Contacts Search",
  "description": "Search, create, edit, and delete your Apple Contacts from Raycast.",
  "icon": "extension-icon.png",
  "author": "adrien",
  "categories": [
    "Productivity",
    "Communication"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-contacts",
      "title": "Search Contacts",
      "subtitle": "Contacts",
      "description": "Search contacts across Apple Contacts with a full detail view.",
      "mode": "view"
    }
  ],
  "preferences": [],
  "dependencies": {
    "@raycast/api": "^1.104.11",
    "@raycast/utils": "^2.2.3",
    "libphonenumber-js": "^1.13.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.x",
    "@types/react": "19.x",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "platforms": [
    "macOS"
  ]
}
